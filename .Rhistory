library('tidyverse')
library(dplyr)
# create a new date column
flights = nycflights13::flights
flights = flights %>% mutate(Date = as.Date(time_hour))
flights = flights %>% group_by(Date, carrier, flight) %>% mutate(once = if_else(n() > 1, FALSE, TRUE))
print(flights %>% filter(once  == FALSE) %>% group_by(Date, carrier, flight) %>% select(Date, carrier, flight, once) %>% head(2))
