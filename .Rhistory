leastSever = analysis %>% group_by(dest) %>% summarise(Avgdelayed = (length(arr_delay[arr_delay >= 30]) / length(arr_delay) ) )
leastSever = leastSever %>% left_join(nycflights13::airports, by = c('dest' = 'faa'))
leastSever %>% select(name, dest, Avgdelayed) %>% arrange(Avgdelayed) %>% head(5)
analysis %>% filter(Date == as.Date('2013-06-13') && dest == 'SNA') %>% group_by(dest) %>% summarise(Avgdelayed = (length(arr_delay[arr_delay >= 30]) / length(arr_delay) ) )
