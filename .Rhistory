airports = airports %>% select(faa, name, lat, lon)
flights = flights %>% left_join(airports, by = c('origin' = 'faa')) %>% left_join(airports, by = c('dest' = 'faa'))
flights = rename(flights, originName = name.x)
flights = rename(flights, originLat = lat.x)
flights = rename(flights, originLon = lon.x)
flights = rename(flights, destName = name.y)
flights = rename(flights, destLat = lat.y)
flights = rename(flights, destLon = lon.y)
print(flights %>% select(Date, carrier, flight, origin, originName, originLat, originLon, dest, destName, destLat, destLon))
weather = nycflights13::weather
analysis = flights %>% left_join(weather, by = c('origin' = 'origin', 'year' = 'year', 'month' = 'month', 'day' = 'day'))
# without NA
plot = analysis %>% group_by(visib) %>% summarise(avgDelay = mean(dep_delay, na.rm = TRUE))
plot
