flights = nycflights13::flights
flights = flights %>% mutate(Date = as.Date(time_hour))
flights = flights %>% group_by(Date, carrier, flight) %>% mutate(once = if_else(n() > 1, FALSE, TRUE))
flights %>% filter(once  == FALSE) %>% group_by(Date, carrier, flight) %>% select(Date, carrier, flight, once) %>% head(2)
airports = nycflights13::airports
airports = airports %>% select(faa, name, lat, lon)
flights = flights %>% left_join(airports, by = c('origin' = 'faa')) %>% left_join(airports, by = c('dest' = 'faa'))
flights = rename(flights, originName = name.x)
flights = rename(flights, originLat = lat.x)
flights = rename(flights, originLon = lon.x)
flights = rename(flights, destName = name.y)
flights = rename(flights, destLat = lat.y)
flights = rename(flights, destLon = lon.y)
flights
flights %>% select(Date, carrier, flight, origin, originName, originLat, originLon, dest, destName, destLat, destLon)
weather = nycflights13::weather
analysis = weather %>% left_join(flights, by = c('origin' = 'origin', 'year' = 'year', 'month' = 'month', 'day' = 'day'))
analysis
plot = analysis %>% group_by(visib) %>% summarise(avgDelay = mean(dep_delay))
plot
plot %>% ggplot(aes(x=visib, y=avgDelay)) + geom_bar(stat='identity')
knitr::opts_chunk$set(echo = TRUE)
